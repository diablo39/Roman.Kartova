<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <TreatWarningsAsErrors>true</TreatWarningsAsErrors>
    <LangVersion>latest</LangVersion>
    <IsPackable>false</IsPackable>
  </PropertyGroup>
  <ItemGroup>
    <PackageReference Include="Microsoft.NET.Test.Sdk" />
    <PackageReference Include="MSTest.TestFramework" />
    <PackageReference Include="MSTest.TestAdapter" />
    <PackageReference Include="MSTest.Analyzers" />
    <PackageReference Include="Microsoft.AspNetCore.Mvc.Testing" />
    <PackageReference Include="Testcontainers.PostgreSql" />
    <PackageReference Include="Npgsql" />
    <!-- Slice-9 carry-forward MT3: NSubstitute is used by InvitationFailureWiringTests
         to override IKeycloakAdminClient via ConfigureTestServices so a forced KC
         role-assign failure exercises the 502 wire mapping end-to-end. -->
    <PackageReference Include="NSubstitute" />
    <PackageReference Include="coverlet.collector" />
  </ItemGroup>
  <ItemGroup>
    <Using Include="Microsoft.VisualStudio.TestTools.UnitTesting" />
  </ItemGroup>
  <ItemGroup>
    <ProjectReference Include="..\..\..\..\src\Kartova.Api\Kartova.Api.csproj" />
    <ProjectReference Include="..\Kartova.Organization.Infrastructure\Kartova.Organization.Infrastructure.csproj" />
    <ProjectReference Include="..\Kartova.Organization.Infrastructure.Admin\Kartova.Organization.Infrastructure.Admin.csproj" />
    <!-- Slice 8: integration tests need to migrate the Catalog schema too so DeleteTeamHandler's
         cross-module IApplicationCountByTeamReader query can resolve. Test-only dependency —
         architecture rules target src/ assemblies, not test assemblies. -->
    <ProjectReference Include="..\..\Catalog\Kartova.Catalog.Infrastructure\Kartova.Catalog.Infrastructure.csproj" />
    <!-- Slice 10 / audit wiring: AuditWiringTests assert rows in audit_log, which requires the
         audit schema to be migrated in the shared Postgres container. Direct reference so
         RunModuleMigrationsAsync can call PostgresTestBootstrap.RunMigrationsAsync<AuditDbContext>. -->
    <ProjectReference Include="..\..\Audit\Kartova.Audit.Infrastructure\Kartova.Audit.Infrastructure.csproj" />
    <ProjectReference Include="..\..\..\..\tests\Kartova.Testing.Auth\Kartova.Testing.Auth.csproj" />
  </ItemGroup>
  <ItemGroup>
    <!-- Slice 9 / H1-prereq: KartovaApiFixtureBase opts into a Keycloak container,
         which mounts kartova-realm.json from AppContext.BaseDirectory. MSBuild does
         not propagate <None CopyToOutputDirectory> items through project references,
         so the include is mirrored here (and in every other consumer that opts in). -->
    <None Include="..\..\..\..\deploy\keycloak\kartova-realm.json" Link="kartova-realm.json">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </None>
  </ItemGroup>
</Project>
